        <mxCell id="health" parent="1" style="shape=swimlane;startSize=200;fillColor=#f8cecc;strokeColor=#b85450;whiteSpace=wrap;html=1;" value="HealthMetric&#xa;────────────&#xa;PK id&#xa;label&#xa;value&#xa;status&#xa;createdAt&#xa;updatedAt" vertex="1">
          <mxGeometry height="200" width="260" x="430" y="450" as="geometry" />
