      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="device" parent="1" style="shape=swimlane;startSize=300;fillColor=#dae8fc;strokeColor=#6c8ebf;whiteSpace=wrap;html=1;" value="Device&#xa;────────────&#xa;PK id&#xa;name&#xa;deviceCode (UQ)&#xa;type&#xa;status&#xa;motionStatus&#xa;ipAddress&#xa;wifiStrength&#xa;firmwareVersion&#xa;lastSeen&#xa;createdAt&#xa;updatedAt" vertex="1">
          <mxGeometry height="300" width="260" x="70" y="80" as="geometry" />
