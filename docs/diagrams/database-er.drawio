        <mxCell id="activity" parent="1" style="shape=swimlane;startSize=240;fillColor=#ffe6cc;strokeColor=#d79b00;whiteSpace=wrap;html=1;" value="Activity&#xa;────────────&#xa;PK id&#xa;deviceName&#xa;type&#xa;title&#xa;message&#xa;activityTime&#xa;createdAt&#xa;updatedAt" vertex="1">
          <mxGeometry height="240" width="260" x="70" y="450" as="geometry" />
