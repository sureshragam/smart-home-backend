        <mxCell id="sensor" parent="1" style="shape=swimlane;startSize=270;fillColor=#d5e8d4;strokeColor=#82b366;whiteSpace=wrap;html=1;" value="SensorReading&#xa;────────────&#xa;PK id&#xa;FK device_id&#xa;temperature&#xa;humidity&#xa;battery&#xa;signalStrength&#xa;readingTime&#xa;createdAt&#xa;updatedAt" vertex="1">
          <mxGeometry height="270" width="260" x="430" y="80" as="geometry" />
